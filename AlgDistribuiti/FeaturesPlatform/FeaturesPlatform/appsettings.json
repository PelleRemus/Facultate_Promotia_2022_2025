{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FeaturesPlatform;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Outbox": {
    "IntervalInSeconds": 5,
    "BatchSize": 20
  },
  "Messaging": {
    "MaxRetryCount": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
